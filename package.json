{
  "name": "vibecheck-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "vibecheck — production-readiness & security auditor for AI-built commerce codebases. Built by MnT.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "pnpm -r typecheck",
    "dev": "pnpm -r build && node packages/cli/dist/index.js",
    "record-fixture": "node packages/core/src/loader/record-fixture.ts",
    "changeset": "changeset",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.27.11",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
